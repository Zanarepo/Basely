function KPICard({ icon: Icon, label, value, sub, trend, color }) {
    return (
        <div className="bg-white rounded-xl border border-slate-200 p-4 flex-1 min-w-[150px]">
            <div className="flex items-center justify-between mb-2">
                <div className={`w-8 h-8 rounded-lg flex items-center justify-center`} style={{ backgroundColor: color + '18' }}>
                    <Icon size={15} style={{ color }} />
                </div>
                {trend && (
                    <span className={`flex items-center gap-0.5 text-[11px] font-medium ${trend > 0 ? 'text-emerald-600' : 'text-rose-600'}`}>
                        {trend > 0 ? <TrendingUp size={11} /> : <TrendingDown size={11} />}
                        {Math.abs(trend)}%
                    </span>
                )}
            </div>
            <div className="text-xl font-semibold text-slate-800">{value}</div>
            <div className="text-[11px] text-slate-400 mt-0.5">{label}</div>
            {sub && <div className="text-[10px] text-slate-400 mt-1">{sub}</div>}
        </div>
    );
}

