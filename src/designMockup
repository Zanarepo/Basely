                    </div>
                ))}
            </div>
            <div className="flex-1 overflow-x-auto bg-white">
                <div className="h-9 border-b border-slate-200 flex items-center px-3 gap-8 text-[10px] text-slate-400 sticky top-0 bg-white z-10">
                    {Array.from({ length: 11 }).map((_, i) => <span key={i} className="w-12">Wk {i + 1}</span>)}
                </div>
                <div className="relative" style={{ minWidth: 720 }}>
                    {/* today marker */}
                    <div className="absolute top-0 bottom-0 border-l-2 border-rose-400 z-10" style={{ left: `${(28 / maxSpan) * 100}%` }}>
                        <span className="absolute -top-0 -left-6 text-[9px] text-rose-500 font-medium bg-rose-50 px-1 rounded">Today</span>
                    </div>
                    {wbsTree.filter(n => n.level > 0).map((wbsNode, rowIdx) => {
                        const task = ganttTasks[rowIdx % ganttTasks.length];
                        return (
                            <div key={wbsNode.id} className="h-9 border-b border-slate-100 relative flex items-center">
                                <div className="absolute h-5 rounded-md flex items-center overflow-hidden shadow-sm"
                                    style={{
                                        left: `${(task.start / maxSpan) * 100}%`,
                                        width: `${(task.dur / maxSpan) * 100}%`,
                                        backgroundColor: task.color + '25',
                                        border: `1.5px solid ${task.critical ? '#ef4444' : task.color}`,
                                    }}>
                                    <div className="h-full rounded-sm" style={{ width: `${task.progress}%`, backgroundColor: task.critical ? '#ef4444' : task.color }} />
                                </div>
                                <span className="absolute text-[10px] text-slate-600 whitespace-nowrap" style={{ left: `calc(${(task.start / maxSpan) * 100}% + ${(task.dur / maxSpan) * 100}% + 6px)` }}>
                                    {task.name} {task.critical && <span className="text-rose-500 font-medium">· CP</span>}
                                </span>
                            </div>
                        );
                    })}
                </div>
            </div>
        </div>
    );
}

